# .gitignore for Ansible projects
# Ignore roles downloaded from Galaxy
!roles/README.md

# Ignore inventory files with sensitive data
*.ini

# Ignore secrets and vault files
secrets.yml
vault.yml
vault_password.yml
.vault
.vault_pass

# Ignore Ansible logs
*.retry
*.log

# Ignore temporary files
*.tmp
*.bak
*.swp

# Ignore Python / venv garbage
__pycache__/
*.pyc
.venv*
.lock

# Ignore SSH keys and vault files
*.pem
*.key
*.vault

# Ignore environment files
.env

# Ignore backup files
*~

# Nix / direnv garbage
.direnv/

# Locally installed Ansible collections
collections/
.collections-installed
